# Transcription Portal — backend
# Скопируйте в .env:  copy .env.example .env  (и заполните секреты). Файл .env в репозиторий не кладут.

# --- Общие ---
APP_NAME=Transcription Backend
ENVIRONMENT=docker
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Пути (при Docker / локальном запуске обычно оставляют по умолчанию) ---
# DATABASE_URL=sqlite:///C:/path/to/backend/data/transcription.db
# STORAGE_PATH=
# STORAGE_DIR=
# MODELS_PATH=
WHISPER_DOWNLOAD_ROOT=models/whisper
# LOGS_PATH=

# --- Whisper / транскрипция ---
DEFAULT_TRANSCRIPTION_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=ru
DEFAULT_DIARIZATION_MODEL=heuristic-2spk

# --- Медиа / загрузка ---
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
MAX_UPLOAD_SIZE_MB=1024

# --- Сводка (summary) — только DeepSeek (OpenAI-совместимый API) или mock / off ---
# mock | off | deepseek (нужен DEEPSEEK_API_KEY, иначе сводка не сгенерируется)
SUMMARY_PROVIDER=deepseek
SUMMARY_MAX_INPUT_CHARS=12000
SUMMARY_TIMEOUT_SECONDS=600
SUMMARY_MAP_REDUCE=true
SUMMARY_CHUNK_SIZE=7000
SUMMARY_CHUNK_OVERLAP=400
SUMMARY_MAX_MAP_CHUNKS=20

# Ключ (обязательно для deepseek)
# DEEPSEEK_API_KEY=
# OpenRouter + R1 (по умолчанию в коде):
# DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
# DEEPSEEK_MODEL=deepseek/deepseek-r1
# Напрямой DeepSeek:
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# Опционально для OpenRouter:
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_X_TITLE=Transcription Portal
